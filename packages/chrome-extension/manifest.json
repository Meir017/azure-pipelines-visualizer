{
  "manifest_version": 3,
  "name": "Azure Pipelines Dependency Viewer",
  "version": "0.1.0",
  "description": "Adds pipeline dependency visualization to Azure DevOps commit pages",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://dev.azure.com/*",
    "https://*.visualstudio.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://dev.azure.com/*", "https://*.visualstudio.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
